# Abstract repository interface — the "port" in hexagonal architecture.
# Concrete implementations (e.g., SQLAlchemy repos) go in separate modules
# and must satisfy this interface.
from __future__ import annotations

import uuid
from abc import ABC, abstractmethod
from typing import Generic, TypeVar

T = TypeVar("T")


class AbstractRepository(ABC, Generic[T]):
    """Base repository defining the data-access contract.

    All concrete repositories (PostgreSQL, in-memory, etc.) must implement
    these methods.  Services depend on this interface, never on a concrete
    implementation — this is the core of the ports-and-adapters pattern.
    """

    @abstractmethod
    async def get_by_id(self, entity_id: uuid.UUID) -> T | None:
        """Retrieve a single entity by its primary key.

        Returns None if not found.
        """

    @abstractmethod
    async def list_all(self, *, offset: int = 0, limit: int = 100) -> list[T]:
        """Return a paginated list of entities."""

    @abstractmethod
    async def create(self, entity: T) -> T:
        """Persist a new entity and return it with any server-generated fields."""

    @abstractmethod
    async def update(self, entity: T) -> T:
        """Update an existing entity and return the updated version."""

    @abstractmethod
    async def delete(self, entity_id: uuid.UUID) -> bool:
        """Delete an entity by ID. Returns True if deleted, False if not found."""
