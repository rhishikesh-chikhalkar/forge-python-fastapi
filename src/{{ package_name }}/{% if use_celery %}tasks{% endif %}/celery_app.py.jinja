# Celery application instance and configuration.
# This module is only generated when use_celery is true.
# Start the worker: celery -A {{ package_name }}.tasks.celery_app worker --loglevel=info
from __future__ import annotations

from celery import Celery

from {{ package_name }}.settings import settings

# Create the Celery application instance
celery_app = Celery(
    "{{ package_name }}",
    broker=settings.CELERY_BROKER_URL,
    backend=settings.CELERY_RESULT_BACKEND,
)

# Celery configuration
celery_app.conf.update(
    task_serializer="json",
    accept_content=["json"],
    result_serializer="json",
    timezone="UTC",
    enable_utc=True,
    task_track_started=True,
    task_acks_late=True,
    worker_prefetch_multiplier=1,
    # Auto-discover tasks in all installed apps
    task_routes={
        "{{ package_name }}.tasks.*": {"queue": "default"},
    },
)


# ---------------------------------------------------------------------------
# Example task — replace or extend with your actual tasks
# ---------------------------------------------------------------------------


@celery_app.task(bind=True, max_retries=3)
def example_task(self, message: str) -> dict[str, str]:  # type: ignore[no-untyped-def]
    """Example Celery task demonstrating basic patterns.

    Args:
        message: A message to process.

    Returns:
        A dict with the processed result.
    """
    try:
        # Simulate work — replace with actual task logic
        result = f"Processed: {message}"
        return {"status": "success", "result": result}
    except Exception as exc:
        # Retry with exponential backoff
        raise self.retry(exc=exc, countdown=2**self.request.retries)
