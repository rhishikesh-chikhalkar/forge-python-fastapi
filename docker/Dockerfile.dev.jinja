# ============================================================================
# Development Dockerfile for {{ project_name }}
# ============================================================================
# Hot-reload enabled via uvicorn --reload.
# Mount source code as a volume for live editing.
# ============================================================================

FROM python:{{ python_version }}-slim

ENV PYTHONDONTWRITEBYTECODE=1 \
    PYTHONUNBUFFERED=1

# Install uv and system dependencies
COPY --from=ghcr.io/astral-sh/uv:latest /uv /usr/local/bin/uv

{% if database == "postgresql" %}
# PostgreSQL client libraries for psycopg2
RUN apt-get update && apt-get install -y --no-install-recommends \
    libpq-dev gcc && \
    rm -rf /var/lib/apt/lists/*
{% elif database == "mysql" %}
# MySQL client libraries for mysqlclient
RUN apt-get update && apt-get install -y --no-install-recommends \
    default-libmysqlclient-dev gcc pkg-config && \
    rm -rf /var/lib/apt/lists/*
{% endif %}

WORKDIR /app

# Install all dependencies including dev extras
COPY pyproject.toml uv.lock* ./
RUN uv sync --frozen

# Copy source and config
COPY src/ src/
COPY alembic.ini ./
COPY tests/ tests/

EXPOSE 8000

# Hot-reload: uvicorn watches for file changes and restarts automatically
CMD ["uv", "run", "uvicorn", "{{ package_name }}.asgi:application", \
     "--reload", "--host", "0.0.0.0", "--port", "8000", \
     "--reload-dir", "src"]
