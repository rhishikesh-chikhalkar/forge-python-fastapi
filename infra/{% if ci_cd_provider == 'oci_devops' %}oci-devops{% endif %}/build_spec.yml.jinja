# OCI DevOps build spec — lint + test stage.
# This runs first in the build pipeline before the Docker build.
version: 0.1
component: build
timeoutInSeconds: 600
shell: bash

steps:
  - type: Command
    name: "Install Python and uv"
    command: |
      echo "Installing Python {{ python_version }} and uv..."
      dnf install -y python{{ python_version }} python{{ python_version }}-pip
      pip{{ python_version }} install uv

  - type: Command
    name: "Install dependencies"
    command: |
      echo "Installing project dependencies..."
      make install

  - type: Command
    name: "Lint (ruff)"
    command: |
      echo "Running linter..."
      make lint

  - type: Command
    name: "Typecheck (mypy)"
    command: |
      echo "Running type checker..."
      make typecheck

  - type: Command
    name: "Run tests"
    command: |
      echo "Running test suite..."
      make test
