variable "compartment_id" {
  description = "OCI compartment OCID for resource provisioning."
  type        = string
}

variable "project_name" {
  description = "Project name, used for resource naming and tagging."
  type        = string
}

variable "environment" {
  description = "Deployment environment (dev, staging, prod)."
  type        = string
}

variable "vcn_cidr" {
  description = "CIDR block for the VCN."
  type        = string
  default     = "10.0.0.0/16"
}

variable "ad_count" {
  description = "Number of availability domains to use for high availability."
  type        = number
  default     = 2
}
