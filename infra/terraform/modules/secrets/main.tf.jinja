# Secrets module — AWS Secrets Manager for storing application secrets.
# The External Secrets Operator in Kubernetes syncs these into k8s Secrets.

terraform {
  required_version = ">= 1.5"
  required_providers {
    aws = {
      source  = "hashicorp/aws"
      version = "~> 5.0"
    }
  }
}

# ---------------------------------------------------------------------------
# Application secrets — database credentials, API keys, etc.
# ---------------------------------------------------------------------------
resource "aws_secretsmanager_secret" "app" {
  name        = "${var.project_name}/${var.environment}/app"
  description = "Application secrets for ${var.project_name} (${var.environment})"

  tags = {
    Name        = "${var.project_name}-app-secrets"
    Environment = var.environment
    ManagedBy   = "terraform"
  }
}

# Initial secret value — update manually or via CI/CD after creation.
resource "aws_secretsmanager_secret_version" "app" {
  secret_id = aws_secretsmanager_secret.app.id

  secret_string = jsonencode({
    DATABASE_URL = var.database_url
    SECRET_KEY   = var.secret_key
    REDIS_URL    = var.redis_url
  })
}
