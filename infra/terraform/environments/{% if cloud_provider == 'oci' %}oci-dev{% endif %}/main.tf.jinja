# Dev environment (OCI) — wires all OCI Terraform modules for development.
# Uses Always Free-eligible shapes to minimise costs.

terraform {
  required_version = ">= 1.5"
  required_providers {
    oci = {
      source  = "oracle/oci"
      version = "~> 6.0"
    }
  }

  # OCI Object Storage supports an S3-compatible API for Terraform state.
  backend "s3" {
    bucket                      = "{{ project_slug }}-terraform-state"
    key                         = "oci-dev/terraform.tfstate"
    region                      = "us-ashburn-1"
    endpoint                    = "https://${var.oci_namespace}.compat.objectstorage.us-ashburn-1.oraclecloud.com"
    skip_region_validation      = true
    skip_credentials_validation = true
    skip_metadata_api_check     = true
    force_path_style            = true
  }
}

provider "oci" {
  region = var.region
}

module "vcn" {
  source         = "../../modules/oci_vcn"
  compartment_id = var.compartment_id
  project_name   = var.project_name
  environment    = "dev"
  vcn_cidr       = "10.0.0.0/16"
  ad_count       = 2
}

module "oke" {
  source             = "../../modules/oci_oke"
  compartment_id     = var.compartment_id
  project_name       = var.project_name
  environment        = "dev"
  region             = var.region
  vcn_id             = module.vcn.vcn_id
  public_subnet_ids  = module.vcn.public_subnet_ids
  private_subnet_ids = module.vcn.private_subnet_ids
  # Always Free-eligible: VM.Standard.A1.Flex, 1 OCPU, 6 GB RAM
  node_shape         = "VM.Standard.A1.Flex"
  node_ocpus         = 1
  node_memory_gb     = 6
  node_count         = 2
  node_image_id      = var.node_image_id
}

module "ocir" {
  source         = "../../modules/oci_ocir"
  compartment_id = var.compartment_id
  project_name   = var.project_name
  environment    = "dev"
  region         = var.region
}

module "vault" {
  source         = "../../modules/oci_vault"
  compartment_id = var.compartment_id
  project_name   = var.project_name
  environment    = "dev"
  database_url   = var.database_url
  secret_key     = var.secret_key
}

module "monitoring" {
  source         = "../../modules/oci_monitoring"
  compartment_id = var.compartment_id
  project_name   = var.project_name
  environment    = "dev"
  cluster_id     = module.oke.cluster_id
}
