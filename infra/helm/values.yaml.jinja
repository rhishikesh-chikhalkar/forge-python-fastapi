# Default Helm values for {{ project_slug }}
# Override per-environment in values-{env}.yaml

replicaCount: 2

image:
{% if cloud_provider == 'aws' %}
  repository: "ACCOUNT_ID.dkr.ecr.us-east-1.amazonaws.com/{{ project_slug }}"
{% elif cloud_provider == 'oci' %}
  repository: "us-ashburn-1.ocir.io/NAMESPACE/{{ project_slug }}"
{% endif %}
  tag: "latest"
  pullPolicy: IfNotPresent

serviceAccount:
  create: true
  name: "{{ project_slug }}-sa"
  annotations:
{% if cloud_provider == 'aws' %}
    # This ARN comes from the Terraform EKS module's app_irsa_role_arn output.
    eks.amazonaws.com/role-arn: "arn:aws:iam::ACCOUNT_ID:role/{{ project_slug }}-dev-app-irsa"
{% elif cloud_provider == 'oci' %}
    # OKE workload identity — pods authenticate via instance principals.
    # Configure matching OCI dynamic group policies for the node pool.
    oke.oraclecloud.com/workload-identity: "true"
{% endif %}

service:
  type: ClusterIP
  port: 8000

ingress:
  enabled: true
{% if cloud_provider == 'aws' %}
  className: alb
  annotations:
    alb.ingress.kubernetes.io/scheme: internet-facing
    alb.ingress.kubernetes.io/target-type: ip
    alb.ingress.kubernetes.io/listen-ports: '[{"HTTPS": 443}]'
    alb.ingress.kubernetes.io/certificate-arn: "arn:aws:acm:us-east-1:ACCOUNT_ID:certificate/CERT_ID"
    alb.ingress.kubernetes.io/ssl-redirect: "443"
{% elif cloud_provider == 'oci' %}
  className: oci-native-ingress
  annotations:
    oci-native-ingress.oraclecloud.com/load-balancer-type: "lb"
    oci-native-ingress.oraclecloud.com/certificate-ocid: "CERT_OCID"
{% endif %}
  hosts:
    - host: "api.example.com"
      paths:
        - path: /
          pathType: Prefix

resources:
  requests:
    cpu: 250m
    memory: 256Mi
  limits:
    cpu: 500m
    memory: 512Mi

autoscaling:
  enabled: true
  minReplicas: 2
  maxReplicas: 10
  targetCPUUtilizationPercentage: 70
  targetMemoryUtilizationPercentage: 80

livenessProbe:
  httpGet:
    path: /api/v1/ping
    port: 8000
  initialDelaySeconds: 10
  periodSeconds: 30

readinessProbe:
  httpGet:
    path: /api/v1/ping
    port: 8000
  initialDelaySeconds: 5
  periodSeconds: 10

env:
  ENVIRONMENT: "development"
  LOG_LEVEL: "INFO"

externalSecrets:
  enabled: true
{% if cloud_provider == 'aws' %}
  secretStoreRef:
    name: aws-secrets-manager
    kind: ClusterSecretStore
  target:
    name: "{{ project_slug }}-secrets"
  data:
    - secretKey: DATABASE_URL
      remoteRef:
        key: "{{ project_slug }}/dev/app"
        property: DATABASE_URL
    - secretKey: SECRET_KEY
      remoteRef:
        key: "{{ project_slug }}/dev/app"
        property: SECRET_KEY
{% elif cloud_provider == 'oci' %}
  secretStoreRef:
    name: oci-vault
    kind: ClusterSecretStore
  target:
    name: "{{ project_slug }}-secrets"
  data:
    - secretKey: DATABASE_URL
      remoteRef:
        key: "{{ project_slug }}-dev-database-url"
    - secretKey: SECRET_KEY
      remoteRef:
        key: "{{ project_slug }}-dev-secret-key"
{% endif %}

networkPolicy:
  enabled: true
