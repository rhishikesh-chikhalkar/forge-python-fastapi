# ============================================================================
# Environment Variables for {{ project_name }}
# ============================================================================
# Copy this file to .env and fill in the values for your local environment.
# Never commit .env to version control — it contains secrets.
# ============================================================================

# ---- Application ----
PROJECT_NAME="{{ project_name }}"
DEBUG=true
ENVIRONMENT=development
SECRET_KEY=change-me-to-a-random-string
ALLOWED_HOSTS=localhost,127.0.0.1

# ---- Server ----
HOST=0.0.0.0
PORT=8000
WORKERS=1

# ---- Database ----
{% if database == "postgresql" -%}
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/{{ package_name }}
{% elif database == "mysql" -%}
DATABASE_URL=mysql+aiomysql://root:root@localhost:3306/{{ package_name }}
{% else -%}
DATABASE_URL=sqlite+aiosqlite:///./{{ package_name }}.db
{% endif %}
# ---- Redis ----
REDIS_URL=redis://localhost:6379/0

# ---- CORS ----
CORS_ORIGINS=http://localhost:3000,http://localhost:8000

# ---- Logging ----
LOG_LEVEL=INFO
LOG_FORMAT=json

{% if use_celery -%}
# ---- Celery ----
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2
{% endif -%}

{% if cloud_provider == 'aws' %}
# ---- AWS (for production deployments) ----
# AWS_REGION=us-east-1
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
{% elif cloud_provider == 'oci' %}
# ---- OCI (for production deployments) ----
# OCI_REGION=us-ashburn-1
# OCI_TENANCY_OCID=
# OCI_USER_OCID=
# OCI_FINGERPRINT=
# OCI_PRIVATE_KEY_PATH=
# OCI_COMPARTMENT_ID={{ oci_compartment_id }}
{% endif %}
