# ============================================================================
# {{ project_name }} — Development Makefile
# ============================================================================
# Convenience targets for common development tasks.
# Run `make help` to list all available targets.
# ============================================================================

.DEFAULT_GOAL := help
.PHONY: help install lint format typecheck test test-unit test-integration run docker-build clean

PACKAGE  := {{ package_name }}
SRC_DIR  := src/$(PACKAGE)
TEST_DIR := tests

help: ## Show this help message
	@grep -E '^[a-zA-Z_-]+:.*?## .*$$' $(MAKEFILE_LIST) | \
		awk 'BEGIN {FS = ":.*?## "}; {printf "  \033[36m%-20s\033[0m %s\n", $$1, $$2}'

# ---------------------------------------------------------------------------
# Installation
# ---------------------------------------------------------------------------

install: ## Install all dependencies (runtime + dev) via uv
	uv sync --all-extras
	pre-commit install

# ---------------------------------------------------------------------------
# Code Quality
# ---------------------------------------------------------------------------

lint: ## Run ruff linter
	uv run ruff check $(SRC_DIR) $(TEST_DIR)

format: ## Auto-format code with ruff
	uv run ruff format $(SRC_DIR) $(TEST_DIR)
	uv run ruff check --fix $(SRC_DIR) $(TEST_DIR)

typecheck: ## Run mypy static type analysis
	uv run mypy $(SRC_DIR)

# ---------------------------------------------------------------------------
# Testing
# ---------------------------------------------------------------------------

test: ## Run the full test suite with coverage
	uv run pytest

test-unit: ## Run unit tests only (fast, no I/O)
	uv run pytest -m unit

test-integration: ## Run integration tests only (requires DB)
	uv run pytest -m integration

# ---------------------------------------------------------------------------
# Development Server
# ---------------------------------------------------------------------------

run: ## Start the development server with hot-reload
	uv run uvicorn $(PACKAGE).asgi:application --reload --host 0.0.0.0 --port 8000

# ---------------------------------------------------------------------------
# Docker
# ---------------------------------------------------------------------------

docker-build: ## Build the production Docker image
	docker build -f docker/Dockerfile -t {{ project_slug }}:latest .

docker-up: ## Start all services via Docker Compose
	docker compose -f docker/docker-compose.yaml up -d

docker-down: ## Stop all Docker Compose services
	docker compose -f docker/docker-compose.yaml down

# ---------------------------------------------------------------------------
# Database
# ---------------------------------------------------------------------------

migrate: ## Run Alembic migrations to head
	uv run alembic upgrade head

migration: ## Create a new Alembic migration (usage: make migration MSG="add users table")
	uv run alembic revision --autogenerate -m "$(MSG)"

# ---------------------------------------------------------------------------
# Cleanup
# ---------------------------------------------------------------------------

clean: ## Remove build artifacts, caches, and coverage reports
	find . -type d -name __pycache__ -exec rm -rf {} + 2>/dev/null || true
	find . -type d -name .pytest_cache -exec rm -rf {} + 2>/dev/null || true
	find . -type d -name .mypy_cache -exec rm -rf {} + 2>/dev/null || true
	find . -type d -name .ruff_cache -exec rm -rf {} + 2>/dev/null || true
	rm -rf dist build *.egg-info htmlcov .coverage .tox
