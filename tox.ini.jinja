# ============================================================================
# tox — Multi-environment test runner for {{ project_name }}
# ============================================================================
# Run all environments:  tox
# Run a specific env:    tox -e py312
# List environments:     tox list
# ============================================================================

[tox]
env_list = py311, py312, py313, lint, typecheck
skip_missing_interpreters = true

[testenv]
deps =
    pytest>=8.3.0
    pytest-asyncio>=0.24.0
    pytest-cov>=6.0.0
    httpx>=0.28.0
    factory-boy>=3.3.0
commands =
    pytest {posargs}

[testenv:lint]
deps =
    ruff>=0.8.0
commands =
    ruff check src/ tests/
    ruff format --check src/ tests/

[testenv:typecheck]
deps =
    mypy>=1.13.0
    pydantic
    pydantic-settings
    fastapi
    sqlalchemy[mypy]
commands =
    mypy src/{{ package_name }}
